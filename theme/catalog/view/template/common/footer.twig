{# Close main content opened in header.twig #}
  </main>

  {{ content_bottom }}
</div>

{# ===== Pre-Footer CTA Banner ===== #}
<section class="mp-prefooter" aria-label="Contact prompt">
  <div class="mp-prefooter__inner">
    <div class="mp-prefooter__content">
      <h2 class="mp-prefooter__heading">Need Help Finding the Right Medical Equipment?</h2>
      <p class="mp-prefooter__text">Our team of specialists is ready to help you find the perfect solution for your healthcare facility.</p>
    </div>
    <a href="{{ contact }}" class="mp-prefooter__btn" data-testid="prefooter-cta">
      <i class="fa-solid fa-headset"></i> Contact Our Team
    </a>
  </div>
</section>

{# ===== Main Footer ===== #}
<footer class="mp-footer" role="contentinfo">
  <div class="mp-footer__main">
    <div class="mp-footer__grid">

      {# Column 1: Company Info #}
      <div class="mp-footer__col mp-footer__col--about">
        <div class="mp-footer__brand">
          <span class="mp-footer__brand-name">Medica Pacifica</span>
          <span class="mp-footer__brand-entity">PTE Limited</span>
        </div>
        <p class="mp-footer__about-text">
          Fiji's leading clinical, laboratory, and medical supplies company. Proudly serving healthcare providers across the Pacific with world-class equipment and supplies.
        </p>
        <div class="mp-footer__social">
          <a href="https://www.facebook.com/medicapacifica" target="_blank" rel="noopener noreferrer" aria-label="Facebook" data-testid="footer-facebook">
            <i class="fa-brands fa-facebook-f"></i>
          </a>
          <a href="https://www.linkedin.com/company/medicapacifica" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" data-testid="footer-linkedin">
            <i class="fa-brands fa-linkedin-in"></i>
          </a>
          <a href="mailto:medica@connect.com.fj" aria-label="Email us" data-testid="footer-email-social">
            <i class="fa-solid fa-envelope"></i>
          </a>
        </div>
      </div>

      {# Column 2: Information Links (from OpenCart) #}
      <div class="mp-footer__col">
        {% if informations %}
          <h3 class="mp-footer__heading">{{ text_information }}</h3>
          <ul class="mp-footer__links">
            {% for information in informations %}
              <li><a href="{{ information.href }}" data-testid="footer-info-{{ loop.index }}">{{ information.title }}</a></li>
            {% endfor %}
          </ul>
        {% endif %}
      </div>

      {# Column 3: Customer Service (OpenCart default links) #}
      <div class="mp-footer__col">
        <h3 class="mp-footer__heading">{{ text_service }}</h3>
        <ul class="mp-footer__links">
          <li><a href="{{ contact }}" data-testid="footer-contact">{{ text_contact }}</a></li>
          <li><a href="{{ return }}" data-testid="footer-return">{{ text_return }}</a></li>
          <li><a href="{{ sitemap }}" data-testid="footer-sitemap">{{ text_sitemap }}</a></li>
        </ul>
        {# Extra links #}
        <h3 class="mp-footer__heading mp-footer__heading--mt">{{ text_extra }}</h3>
        <ul class="mp-footer__links">
          <li><a href="{{ manufacturer }}" data-testid="footer-manufacturer">{{ text_manufacturer }}</a></li>
          <li><a href="{{ voucher }}" data-testid="footer-voucher">{{ text_voucher }}</a></li>
          <li><a href="{{ affiliate }}" data-testid="footer-affiliate">{{ text_affiliate }}</a></li>
          <li><a href="{{ special }}" data-testid="footer-special">{{ text_special }}</a></li>
        </ul>
      </div>

      {# Column 4: Contact Details #}
      <div class="mp-footer__col">
        <h3 class="mp-footer__heading">Contact Us</h3>
        <ul class="mp-footer__contact">
          <li>
            <i class="fa-solid fa-location-dot"></i>
            <span>18 Disraeli Road<br>Suva, Fiji</span>
          </li>
          <li>
            <i class="fa-solid fa-phone"></i>
            <a href="tel:+6793310865" data-testid="footer-phone">+679 3310 865</a>
          </li>
          <li>
            <i class="fa-solid fa-envelope"></i>
            <a href="mailto:medica@connect.com.fj" data-testid="footer-email">medica@connect.com.fj</a>
          </li>
          <li>
            <i class="fa-solid fa-clock"></i>
            <span>Mon &ndash; Fri: 8:00 AM &ndash; 5:00 PM</span>
          </li>
        </ul>
        {# Account links #}
        <h3 class="mp-footer__heading mp-footer__heading--mt">{{ text_account }}</h3>
        <ul class="mp-footer__links">
          <li><a href="{{ account }}" data-testid="footer-account">{{ text_account }}</a></li>
          <li><a href="{{ order }}" data-testid="footer-order">{{ text_order }}</a></li>
          <li><a href="{{ wishlist }}" data-testid="footer-wishlist">{{ text_wishlist }}</a></li>
          <li><a href="{{ newsletter }}" data-testid="footer-newsletter">{{ text_newsletter }}</a></li>
        </ul>
      </div>

    </div>
  </div>

  {# ===== Bottom Bar ===== #}
  <div class="mp-footer__bottom">
    <div class="mp-footer__bottom-inner">
      <p class="mp-footer__copyright">
        &copy; {{ "now"|date("Y") }} Medica Pacifica PTE Limited. {{ powered }}
      </p>
      <div class="mp-footer__legal">
        {% if informations %}
          {% for information in informations %}
            <a href="{{ information.href }}">{{ information.title }}</a>
            {% if not loop.last %}<span class="mp-footer__legal-sep">|</span>{% endif %}
          {% endfor %}
        {% endif %}
      </div>
    </div>
  </div>
</footer>

<style>
  /* ============================================================
     Medica Pacifica - Footer Component Styles
     Supplements the main medicapacifica.css stylesheet
     ============================================================ */

  /* ===== Pre-Footer CTA Banner ===== */
  .mp-prefooter {
    background: linear-gradient(135deg, #0891B2 0%, #0E7490 50%, #0A2240 100%);
    padding: 52px 20px;
  }
  .mp-prefooter__inner {
    max-width: 1320px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    flex-wrap: wrap;
  }
  .mp-prefooter__heading {
    font-family: 'Merriweather', Georgia, serif;
    font-size: 1.75rem;
    color: #FFFFFF;
    margin: 0 0 8px;
    font-weight: 700;
    line-height: 1.3;
  }
  .mp-prefooter__text {
    color: rgba(255, 255, 255, 0.85);
    font-size: 1rem;
    margin: 0;
    max-width: 520px;
  }
  .mp-prefooter__btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #E86C47;
    color: #FFFFFF;
    padding: 16px 36px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
    font-family: 'Inter', sans-serif;
    transition: background 0.2s, transform 0.15s;
    white-space: nowrap;
  }
  .mp-prefooter__btn:hover {
    background: #D4552F;
    color: #FFFFFF;
    transform: translateY(-2px);
  }

  /* ===== Main Footer ===== */
  .mp-footer {
    background: #0A2240;
    color: #FFFFFF;
  }
  .mp-footer__main {
    padding: 60px 0 40px;
  }
  .mp-footer__grid {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 20px;
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1.2fr;
    gap: 40px;
  }

  /* Brand / About */
  .mp-footer__brand {
    margin-bottom: 16px;
  }
  .mp-footer__brand-name {
    font-family: 'Merriweather', Georgia, serif;
    font-size: 1.375rem;
    font-weight: 700;
    color: #FFFFFF;
    display: block;
    line-height: 1.2;
  }
  .mp-footer__brand-entity {
    font-size: 0.75rem;
    color: #0891B2;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .mp-footer__about-text {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.875rem;
    line-height: 1.7;
    margin: 0 0 20px;
  }
  .mp-footer__social {
    display: flex;
    gap: 10px;
  }
  .mp-footer__social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    color: #FFFFFF;
    text-decoration: none;
    font-size: 0.9375rem;
    transition: background 0.2s, transform 0.2s;
  }
  .mp-footer__social a:hover {
    background: #0891B2;
    transform: translateY(-2px);
  }

  /* Footer Headings */
  .mp-footer__heading {
    font-family: 'Inter', sans-serif;
    font-size: 0.9375rem;
    font-weight: 700;
    color: #FFFFFF;
    margin: 0 0 18px;
    padding-bottom: 10px;
    border-bottom: 2px solid #0891B2;
    display: inline-block;
  }
  .mp-footer__heading--mt {
    margin-top: 24px;
  }

  /* Footer Links */
  .mp-footer__links {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .mp-footer__links li {
    margin-bottom: 9px;
  }
  .mp-footer__links a {
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    font-size: 0.875rem;
    transition: color 0.2s, padding-left 0.2s;
    display: inline-block;
  }
  .mp-footer__links a:hover {
    color: #0891B2;
    padding-left: 4px;
  }

  /* Footer Contact */
  .mp-footer__contact {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .mp-footer__contact li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 14px;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.875rem;
    line-height: 1.5;
  }
  .mp-footer__contact li i {
    color: #0891B2;
    font-size: 0.875rem;
    margin-top: 3px;
    min-width: 16px;
    text-align: center;
  }
  .mp-footer__contact a {
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    transition: color 0.2s;
  }
  .mp-footer__contact a:hover {
    color: #0891B2;
  }

  /* ===== Bottom Bar ===== */
  .mp-footer__bottom {
    background: #061529;
    padding: 18px 0;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }
  .mp-footer__bottom-inner {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
  }
  .mp-footer__copyright {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.8125rem;
    margin: 0;
  }
  .mp-footer__legal {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .mp-footer__legal a {
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    font-size: 0.8125rem;
    transition: color 0.2s;
  }
  .mp-footer__legal a:hover {
    color: #0891B2;
  }
  .mp-footer__legal-sep {
    color: rgba(255, 255, 255, 0.2);
    font-size: 0.75rem;
  }

  /* ===== Footer Responsive ===== */
  @media (max-width: 991.98px) {
    .mp-footer__grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 767.98px) {
    .mp-footer__grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .mp-prefooter {
      padding: 36px 20px;
    }
    .mp-prefooter__inner {
      flex-direction: column;
      text-align: center;
    }
    .mp-prefooter__heading {
      font-size: 1.375rem;
    }
    .mp-prefooter__text {
      max-width: 100%;
    }
    .mp-footer__bottom-inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>

{# OpenCart footer scripts #}
{% for script in scripts %}
  <script src="{{ script.href }}" type="text/javascript"></script>
{% endfor %}

{# Medica Pacifica custom JavaScript #}
<script src="catalog/view/theme/medicapacifica/javascript/medicapacifica.js" type="text/javascript"></script>

</body>
</html>
